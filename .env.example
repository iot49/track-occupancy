# DNS: Add a wildcard A record in Cloudflare: *.yourdomain.com → <server-LAN-IP>
# This allows Traefik to obtain a wildcard TLS cert via DNS-01 challenge,
# and makes all subdomains (ui., throttle., mqtt., rocrail.) resolvable on the local network.

# Domain configuration (standardized for both local clients and edge server Docker compose)
DOMAIN=rails49.org
RAILS_DOMAIN=rails49.org

# Traefik & SSL (Cloudflare DNS-01 challenge credentials)
CF_DNS_API_TOKEN=your-cloudflare-api-token-here
CF_API_EMAIL=your@email.com

# Edge Server Environment & Security settings
BALENA_FLEET=rails49
TZ=Europe/Berlin
PUID=1000
PGID=1000
VSCODE_AUTH=none

# Track-occupancy detector settings (Optional edge-server overrides)
# CAMERA_URL=http://192.168.1.x/snapshot.jpg
# INTERVAL_MS=1000
